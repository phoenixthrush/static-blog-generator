{% extends "layout.jinja" %}

{% block title %}{{ title }}{% endblock %}

{% block main %}
    <article id="top">
        <header class="article-header">
            {% if weekday %}
                <p class="article-weekday">{{ weekday }}</p>
            {% endif %}
            {% if age is not none %}
                <p class="article-age">age {{ age }}</p>
            {% endif %}

            <h1>{{ title }}</h1>
        </header>

        {% if content %}
            <div class="post-text">
                {{ content | safe }}
            </div>
        {% endif %}

        {% if assets %}
            <section class="assets">
                <h2>Assets:</h2>

                {% for asset in assets %}
                    <div class="asset">
                        <p><a href="{{ asset.url }}">{{ asset.name }} ({{ asset.size }})</a></p>

                        {% if asset.kind == "image" %}
                            <img src="{{ asset.url }}" alt="{{ asset.name }}">
                        {% elif asset.kind == "video" %}
                            <video controls src="{{ asset.url }}"></video>
                        {% elif asset.kind == "audio" %}
                            <audio controls src="{{ asset.url }}"></audio>
                        {% elif asset.kind == "text" %}
                            <pre>{{ asset.content }}</pre>
                        {% endif %}
                    </div>
                {% endfor %}
            </section>
        {% endif %}

        <nav class="post-nav">
            {% if newer_post %}
                <a href="{{ newer_post.slug }}.html" class="post-nav-prev">&lt;</a>
            {% else %}
                <span></span>
            {% endif %}

            <a href="#top" class="post-nav-top">&lt;back to top&gt;</a>

            {% if older_post %}
                <a href="{{ older_post.slug }}.html" class="post-nav-next">&gt;</a>
            {% else %}
                <span></span>
            {% endif %}
        </nav>
    </article>

    <script>
    document.addEventListener("keydown", async function (event) {
        const key = event.key.toLowerCase();

        const prev = document.querySelector(".post-nav-prev");
        const next = document.querySelector(".post-nav-next");

        // Navigate between posts with arrow keys or Vim-style bindings.
        if ((key === "arrowleft" || key === "h") && prev) {
            window.location.href = prev.href;
            return;
        }

        if ((key === "arrowright" || key === "l") && next) {
            window.location.href = next.href;
            return;
        }

        // Only handle fullscreen shortcuts on a fresh F key press.
        if (key !== "f" || event.repeat) {
            return;
        }

        let playingVideo = null;

        // Find the first video that is currently playing.
        document.querySelectorAll("video").forEach(function(video) {
            if (!playingVideo && !video.paused && !video.ended) {
                playingVideo = video;
            }
        });

        // Do nothing if no video is playing.
        if (!playingVideo) {
            return;
        }

        // Shift+F toggles the browser's native fullscreen mode.
        if (event.shiftKey) {
            try {
                if (document.fullscreenElement) {
                    await document.exitFullscreen();
                } else {
                    await playingVideo.requestFullscreen();
                }
            } catch (err) {
                console.error(err);
            }

            return;
        }

        // F toggles fullscreen within the page layout.
        playingVideo.classList.toggle("fullscreen-video");
    });

    // Escape exits page-level fullscreen mode.
    document.addEventListener("keydown", function(event) {
        if (event.key === "Escape") {
            document.querySelectorAll(".fullscreen-video").forEach(function(video) {
                video.classList.remove("fullscreen-video");
            });
        }
    });
    </script>

{% endblock %}
